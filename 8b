# Base class
class Employee:
    def __init__(self, name, salary):
        self.name = name
        self.salary = salary

    def display(self):
        print(f"Employee Name: {self.name}, Salary: {self.salary}")


# Derived class 1
class Clerk(Employee):
    def __init__(self, name, salary, department):
        super().__init__(name, salary)
        self.department = department

    def display(self):
        print(f"Clerk Name: {self.name}, Salary: {self.salary}, Department: {self.department}")


# Derived class 2
class SoftwareEngineer(Employee):
    def __init__(self, name, salary, language):
        super().__init__(name, salary)
        self.language = language

    def display(self):
        print(f"Software Engineer Name: {self.name}, Salary: {self.salary}, Language: {self.language}")


# Derived class 3 (inherits from SoftwareEngineer)
class TeamLeader(SoftwareEngineer):
    def __init__(self, name, salary, language, team_size):
        super().__init__(name, salary, language)
        self.team_size = team_size

    def display(self):
        print(f"Team Leader Name: {self.name}, Salary: {self.salary}, "
              f"Language: {self.language}, Team Size: {self.team_size}")


# Main function
def main():
    c = Clerk("John", 25000, "Accounts")
    se = SoftwareEngineer("Alice", 60000, "Python")
    tl = TeamLeader("Bob", 80000, "Java", 5)

    c.display()
    se.display()
    tl.display()


main()
