import os

def display_folder_contents(path):
    for root, dirs, files in os.walk(path):
        print(f"\nDirectory: {root}")

        for d in dirs:
            print(f" [Folder] {d}")

        for f in files:
            print(f" [File] {f}")

def main():
    folder = input("Enter folder path: ")

    if os.path.exists(folder):
        display_folder_contents(folder)
    else:
        print("Invalid folder path!")

main()
